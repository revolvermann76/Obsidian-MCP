{
  "name": "obsidian-mcp",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.cjs",
  "type": "module",
  "scripts": {
    "prebuild": "npm ci",
    "build": "npm run typecheck && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --external:better-sqlite3 --outfile=dist/index.cjs",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=cjs --external:better-sqlite3 --outfile=dist/index.cjs --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "format:check": "prettier --check src/",
    "start:test": "npm run build && node dist/index.cjs --vault ./test-vault --db ./test-vault/.mcp-index.db --instructions ./INSTRUCTIONS.md",
    "start:http": "npm run build && node dist/index.cjs --vault /mnt/datastore/mega/my/documents/notes/zettelkasten2/zettelkasten/documents/ --transport http",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.cjs --vault ./test-vault --db ./test-vault/.mcp-index.db --instructions ./INSTRUCTIONS.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revolvermann76/Obsidian-MCP.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/revolvermann76/Obsidian-MCP/issues"
  },
  "homepage": "https://github.com/revolvermann76/Obsidian-MCP#readme",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "~26.0.0",
    "esbuild": "^0.28.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "~4.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3"
  }
}